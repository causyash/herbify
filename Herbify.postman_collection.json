{
  "info": {
    "name": "Herbify API",
    "_postman_id": "herbify-api-collection-v1",
    "description": "Complete API collection for the Herbify e-commerce platform.\n\n## Setup\n1. Set the `baseUrl` variable to your local server (default: `http://localhost:5000`) or production URL.\n2. After a successful login, copy the `token` from the response and set it as the `authToken` collection variable.\n3. Admin-only routes require an account with `role: \"admin\"`.\n\n## Variables\n- `baseUrl` — API root URL\n- `authToken` — JWT access token (set after login)\n- `productSlug` — A valid product slug (e.g. `tulsi-kadha`)\n- `herbSlug` — A valid herb slug (e.g. `ashwagandha`)\n- `orderId` — A valid MongoDB order ObjectId\n- `categoryId` — A valid MongoDB category ObjectId\n- `productId` — A valid MongoDB product ObjectId\n- `herbId` — A valid MongoDB herb ObjectId\n- `userId` — A valid MongoDB user ObjectId\n- `contactId` — A valid MongoDB contact message ObjectId",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "https://herbify-backend.onrender.com", "type": "string" },
    { "key": "authToken",   "value": "",                      "type": "string" },
    { "key": "productSlug", "value": "tulsi-kadha",           "type": "string" },
    { "key": "herbSlug",    "value": "ashwagandha",           "type": "string" },
    { "key": "orderId",     "value": "",                      "type": "string" },
    { "key": "categoryId",  "value": "",                      "type": "string" },
    { "key": "productId",   "value": "",                      "type": "string" },
    { "key": "herbId",      "value": "",                      "type": "string" },
    { "key": "userId",      "value": "",                      "type": "string" },
    { "key": "contactId",   "value": "",                      "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api","health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"code\": \"123456\",\n  \"rememberBrowser\": false\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["api","auth","verify-otp"] }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/resend-otp", "host": ["{{baseUrl}}"], "path": ["api","auth","resend-otp"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('authToken', json.token);",
                  "  console.log('✅ authToken saved:', json.token.substring(0,30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "description": "On success, the `authToken` collection variable is automatically set via the Tests tab script."
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] }
          }
        },
        {
          "name": "[DEV] Setup Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/setup-admin?email=admin@example.com",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","setup-admin"],
              "query": [{ "key": "email", "value": "admin@example.com" }]
            },
            "description": "⚠️ Development helper only. Creates or upgrades an account to admin with password `password123`."
          }
        }
      ]
    },
    {
      "name": "Categories (Public)",
      "item": [
        {
          "name": "List Categories (tree)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api","categories"] }
          }
        }
      ]
    },
    {
      "name": "Herbs (Public)",
      "item": [
        {
          "name": "List Herbs",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/herbs?page=1&limit=12",
              "host": ["{{baseUrl}}"],
              "path": ["api","herbs"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "12" },
                { "key": "q",     "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Herb by Slug",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/herbs/{{herbSlug}}", "host": ["{{baseUrl}}"], "path": ["api","herbs","{{herbSlug}}"] }
          }
        }
      ]
    },
    {
      "name": "Products (Public)",
      "item": [
        {
          "name": "List Products",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1&limit=12",
              "host": ["{{baseUrl}}"],
              "path": ["api","products"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "limit",    "value": "12" },
                { "key": "q",        "value": "", "disabled": true },
                { "key": "category", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Product by Slug",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/products/{{productSlug}}", "host": ["{{baseUrl}}"], "path": ["api","products","{{productSlug}}"] }
          }
        }
      ]
    },
    {
      "name": "Reviews (Public + Auth)",
      "item": [
        {
          "name": "Get Reviews for Item",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/reviews/product/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","reviews","product","{{productId}}"],
              "variable": [{ "key": "itemType", "value": "product", "description": "product or herb" }]
            },
            "description": "Replace `product` with `herb` for herb reviews."
          }
        },
        {
          "name": "Post Review",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"text\": \"Amazing product! Highly recommend.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reviews/product/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","reviews","product","{{productId}}"]
            },
            "description": "Requires authentication. One review per user per item."
          }
        }
      ]
    },
    {
      "name": "Cart (Auth)",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api","cart"] }
          }
        },
        {
          "name": "Update Cart",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"itemType\": \"product\",\n      \"itemId\": \"{{productId}}\",\n      \"slug\": \"{{productSlug}}\",\n      \"name\": \"Tulsi Kadha\",\n      \"price\": 299,\n      \"image\": \"https://example.com/image.jpg\",\n      \"qty\": 2\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api","cart"] },
            "description": "Replaces the entire cart. Pass an empty `items` array to clear."
          }
        }
      ]
    },
    {
      "name": "Orders (Auth)",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": {\n    \"fullName\": \"Test User\",\n    \"phone\": \"9999999999\",\n    \"addressLine1\": \"123 Green Street\",\n    \"addressLine2\": \"Apt 4B\",\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\",\n    \"pincode\": \"400001\"\n  }\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api","orders"] },
            "description": "Creates an order from the user's current cart. Cart must not be empty."
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/orders/my", "host": ["{{baseUrl}}"], "path": ["api","orders","my"] }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api","orders","{{orderId}}"] }
          }
        }
      ]
    },
    {
      "name": "Payments (Auth)",
      "item": [
        {
          "name": "Create Razorpay Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/payments/razorpay/create-order", "host": ["{{baseUrl}}"], "path": ["api","payments","razorpay","create-order"] }
          }
        },
        {
          "name": "Verify Razorpay Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"razorpay_order_id\": \"order_XXXXXXXXXXXX\",\n  \"razorpay_payment_id\": \"pay_XXXXXXXXXXXX\",\n  \"razorpay_signature\": \"<hmac_sha256_signature>\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/payments/razorpay/verify", "host": ["{{baseUrl}}"], "path": ["api","payments","razorpay","verify"] }
          }
        }
      ]
    },
    {
      "name": "Users (Auth)",
